<?xml version="1.0" encoding="utf-8"?>
<!--
  AndroidManifest.xml — Manifiesto de la aplicación GymProFit
  Declara permisos, el FileProvider, todas las Activities de la app
  y la Activity de arranque (SplashActivity) con su intent-filter LAUNCHER.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permisos requeridos: red, notificaciones, cámara/galería (foto de perfil) y contactos -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />

    <application
        android:allowBackup="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.GymProFit">
        <!-- Activities de administración (gestión de usuarios, rutinas, ejercicios, alimentos) -->
        <activity
            android:name=".ui.activities.AdminActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.AdminUsuariosActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.AdminRutinasActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.AdminEjerciciosActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.EditarRutinaAdminActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.EditarEjercicioAdminActivity"
            android:exported="false" />
        <!-- Perfil, logros y mediciones corporales -->
        <activity
            android:name=".ui.activities.EditarPerfilActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.LogrosActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.RegistrarMedicionActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.MedicionesActivity"
            android:exported="false" />
        <!-- Sesiones de entrenamiento -->
        <activity
            android:name=".ui.activities.RegistrarSesionActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.ResumenSesionActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.SesionesActivity"
            android:exported="false" />
        <!-- Registro de usuario y flujo de onboarding (pasos 1 a 5 + resumen) -->
        <activity
            android:name=".ui.activities.RegistroActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.OnboardingResumenActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.Onboarding4Activity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.Onboarding5Activity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.Onboarding3Activity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.Onboarding2Activity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.Onboarding1Activity"
            android:exported="false" />
        <!-- Rutinas: edición, detalle, creación y gestión de ejercicios asociados -->
        <activity
            android:name=".ui.activities.EditarRutinaActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.DetalleRutinaActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.DetalleEjercicioActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.ResumenCrearRutinaActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.AnadirEjerciciosActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.CrearRutinaActivity"
            android:exported="false" />
        <!-- Pantallas principales de navegación (perfil, nutrición, ejercicios, rutinas, home, login) -->
        <activity
            android:name=".ui.activities.PerfilActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.NutricionActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.EjerciciosActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.RutinasActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.HomeActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.LoginActivity"
            android:exported="false" />
        <!-- Nutrición: comidas y alimentos (registro, alta y administración) -->
        <activity android:name=".ui.activities.ComidaActivity" android:exported="false" />
        <activity android:name=".ui.activities.AnadirAlimentoActivity" android:exported="false" />
        <activity android:name=".ui.activities.CrearAlimentoActivity" android:exported="false" />
        <activity android:name=".ui.activities.AdminAlimentosActivity" android:exported="false" />
        <activity android:name=".ui.activities.AcercaDeActivity" android:exported="false" />

        <!-- FileProvider para compartir/capturar la foto de perfil con la cámara -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

        <!-- Activity de arranque (launcher), decide a qué pantalla redirigir según sesión -->
        <activity
            android:name=".ui.activities.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>