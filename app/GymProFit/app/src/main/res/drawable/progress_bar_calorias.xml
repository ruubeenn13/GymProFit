<?xml version="1.0" encoding="utf-8"?>
<!--
  progress_bar_calorias — Drawable de barra de progreso de calorías.
  Layer-list para una ProgressBar horizontal: fondo semitransparente y relleno de progreso en blanco.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Fondo de la barra (pista) -->
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <corners android:radius="4dp" />
            <solid android:color="#40FFFFFF" />
        </shape>
    </item>

    <!-- Relleno de progreso (recortado según el valor actual) -->
    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle">
                <corners android:radius="4dp" />
                <solid android:color="#FFFFFF" />
            </shape>
        </clip>
    </item>

</layer-list>