<!--
  ic_flag_en — icono de la bandera del Reino Unido (Union Jack).
  Se usa como selector de idioma inglés en los ajustes de la app.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="22dp"
    android:height="15dp"
    android:viewportWidth="60"
    android:viewportHeight="40">
    <!-- Blue background -->
    <path android:fillColor="#012169" android:pathData="M0,0 H60 V40 H0 Z"/>
    <!-- White saltire (Saint Andrew) -->
    <path android:fillColor="#FFFFFF" android:pathData="M0,0 L7.2,0 L60,35.2 L60,40 L52.8,40 L0,4.8 Z"/>
    <path android:fillColor="#FFFFFF" android:pathData="M60,0 L52.8,0 L0,35.2 L0,40 L7.2,40 L60,4.8 Z"/>
    <!-- Red saltire (Saint Patrick) – counterchanged -->
    <path android:fillColor="#C8102E" android:pathData="M0,0 L3.6,0 L30,17 L30,20 L26.4,20 L0,4.8 Z"/>
    <path android:fillColor="#C8102E" android:pathData="M60,0 L60,4.8 L33.6,20 L30,20 L30,17 L56.4,0 Z"/>
    <path android:fillColor="#C8102E" android:pathData="M0,40 L0,35.2 L26.4,20 L30,20 L30,23 L3.6,40 Z"/>
    <path android:fillColor="#C8102E" android:pathData="M60,40 L56.4,40 L30,23 L30,20 L33.6,20 L60,35.2 Z"/>
    <!-- White fess (Saint George base) -->
    <path android:fillColor="#FFFFFF" android:pathData="M0,16 H60 V24 H0 Z"/>
    <path android:fillColor="#FFFFFF" android:pathData="M26,0 H34 V40 H26 Z"/>
    <!-- Red cross (Saint George) -->
    <path android:fillColor="#C8102E" android:pathData="M0,18 H60 V22 H0 Z"/>
    <path android:fillColor="#C8102E" android:pathData="M28,0 H32 V40 H28 Z"/>
</vector>
