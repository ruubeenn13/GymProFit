<?xml version="1.0" encoding="utf-8"?>
<!--
  barlow_condensed — familia tipográfica display de la app (rediseño atlético).
  Condensada y contundente: se usa en números grandes, títulos y stats.
  El cuerpo de texto sigue siendo la fuente del sistema (Roboto).
-->
<font-family xmlns:android="http://schemas.android.com/apk/res/android">
    <font
        android:font="@font/barlow_condensed_medium"
        android:fontStyle="normal"
        android:fontWeight="500" />
    <font
        android:font="@font/barlow_condensed_semibold"
        android:fontStyle="normal"
        android:fontWeight="600" />
    <font
        android:font="@font/barlow_condensed_bold"
        android:fontStyle="normal"
        android:fontWeight="700" />
</font-family>
