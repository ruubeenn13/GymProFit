    <string name="acerca_btn">Sobre GymProFit</string>
    <string name="acerca_app_titulo">Sobre la aplicación</string>
    <string name="acerca_app_descripcion">GymProFit es una aplicación móvil de fitness personal diseñada para centralizar el seguimiento de tu vida deportiva. Desde la creación de rutinas personalizadas hasta el control nutricional diario, pasando por el registro de mediciones corporales y el historial completo de sesiones de entrenamiento, todo en un solo lugar.\n\nDesarrollada como Trabajo Final de Ciclo del CFGS DAM, con una API REST en Spring Boot, base de datos MariaDB y cliente Android nativo en Java. Autenticación JWT, documentación Swagger, migraciones con Flyway y consultas avanzadas con jOOQ.</string>
    <string name="acerca_funcionalidades">Funcionalidades</string>
    <string name="acerca_feat_1">Rutinas de entrenamiento personalizadas por grupos musculares y nivel de dificultad</string>
    <string name="acerca_feat_2">Registro de sesiones de entrenamiento con valoración, notas y progreso de ejercicios</string>
    <string name="acerca_feat_3">Seguimiento nutricional diario por comidas con cálculo automático de macros y calorías</string>
    <string name="acerca_feat_4">Historial de mediciones corporales (peso, grasa, músculo, perímetros)</string>
    <string name="acerca_feat_5">Sistema de logros desbloqueables y estadísticas personales de entrenamiento</string>
    <string name="acerca_feat_6">Panel de administración para gestión de usuarios, rutinas, ejercicios y alimentos</string>
