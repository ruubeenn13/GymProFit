<?xml version="1.0" encoding="utf-8"?>
<!--
  colors.xml — paleta de colores de la app (tema claro y oscuro).
  Incluye colores base Material, acentos de marca (dorado/naranja) y chips de estado.
-->
<resources>
    <!-- Colores del tema claro -->
    <color name="primary_light">#E8710A</color>
    <color name="on_primary_light">#FFFFFF</color>
    <color name="surface_light">#FFFFFF</color>
    <color name="on_surface_light">#1A1A1A</color>
    <color name="background_light">#F5F5F5</color>
    <color name="primary_container_light">#FFE0C2</color>
    <color name="on_primary_container_light">#2D1600</color>

    <!-- Colores del tema oscuro -->
    <color name="primary_dark">#CBA135</color>
    <color name="on_primary_dark">#1E1E1E</color>
    <color name="surface_dark">#1E1E1E</color>
    <color name="on_surface_dark">#E8E8E8</color>
    <color name="background_dark">#121212</color>

    <!-- Colores de marca (acentos dorado/naranja) -->
    <color name="golden">#CBA135</color>
    <color name="golden_light">#D4AF37</color>
    <color name="orange_primary">#E8710A</color>
    <color name="orange_dark">#FF8C2A</color>

    <!-- Colores de texto para tema oscuro -->
    <color name="text_primary_dark">#E8E8E8</color>
    <color name="text_secondary_dark">#B0B0B0</color>

    <!-- Colores base -->
    <color name="black">#000000</color>
    <color name="white">#FFFFFF</color>

    <!-- Colores adicionales de superficie/contenedor -->
    <color name="on_surface">#1A1A1A</color>
    <color name="primaryContainer_dark">#2A2A2A</color>
    <color name="onPrimaryContainer_dark">#E8E8E8</color>

    <!-- Colores de tarjetas/cards -->
    <color name="surface_card">#FFFFFF</color>
    <color name="surface_card_2">#F5F5F5</color>
    <color name="text_secondary">#6B6B6B</color>

    <!-- Colores de chips de estado (positivo/negativo) -->
    <color name="green_chip">#E8F5E9</color>
    <color name="green_chip_text">#2E7D32</color>
    <color name="red_chip">#FFEBEE</color>
    <color name="red_chip_text">#C62828</color>
</resources>