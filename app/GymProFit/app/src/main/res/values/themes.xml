<resources>
    <!--
      themes.xml — tema "atlético" de GymProFit (variante CLARA del DayNight;
      values-night define la oscura, que es la por defecto).
      Además de los colores M3, fija ESTILOS GLOBALES de widget (cards,
      botones, chips, bottom nav, dialogs) para que todas las pantallas
      hereden el rediseño sin tocar cada layout.
    -->
    <style name="Theme.GymProFit" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Paleta M3 mapeada a los tokens gp_* -->
        <item name="colorPrimary">@color/gp_primary</item>
        <item name="colorOnPrimary">@color/gp_on_primary</item>
        <item name="colorPrimaryContainer">@color/gp_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/gp_on_primary_container</item>
        <item name="colorSecondary">@color/gp_gold</item>
        <item name="colorSurface">@color/gp_surface</item>
        <item name="colorOnSurface">@color/gp_on_surface</item>
        <item name="colorSurfaceVariant">@color/gp_surface_2</item>
        <item name="colorOnSurfaceVariant">@color/gp_text_secondary</item>
        <item name="colorOutline">@color/gp_stroke</item>
        <item name="colorOutlineVariant">@color/gp_stroke</item>
        <item name="colorError">@color/gp_error</item>
        <item name="android:colorBackground">@color/gp_background</item>
        <item name="android:windowBackground">@color/gp_background</item>
        <item name="android:textColorPrimary">@color/gp_on_surface</item>
        <item name="android:textColorSecondary">@color/gp_text_secondary</item>

        <!-- Barras del sistema integradas con el fondo -->
        <item name="android:statusBarColor">@color/gp_background</item>
        <item name="android:navigationBarColor">@color/gp_background</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Estilos globales de widget (el rediseño entero cuelga de aquí) -->
        <item name="materialCardViewStyle">@style/Widget.GymProFit.Card</item>
        <item name="materialButtonStyle">@style/Widget.GymProFit.Button</item>
        <item name="chipStyle">@style/Widget.GymProFit.Chip</item>
        <item name="bottomNavigationStyle">@style/Widget.GymProFit.BottomNavigationView</item>
        <item name="floatingActionButtonStyle">@style/Widget.GymProFit.Fab</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.GymProFit.Dialog</item>
        <item name="popupMenuStyle">@style/Widget.GymProFit.PopupMenu</item>
        <item name="android:popupMenuStyle">@style/Widget.GymProFit.PopupMenu</item>
        <item name="snackbarStyle">@style/Widget.GymProFit.Snackbar</item>

        <!-- Fuente ÚNICA en toda la app (Barlow Condensed, la de Home/Nutrición).
             fontFamily del tema = catch-all para TextViews; la escala tipográfica M3
             (abajo) fuerza la fuente también en botones, chips, diálogos, inputs... -->
        <item name="android:fontFamily">@font/barlow_condensed</item>
        <item name="fontFamily">@font/barlow_condensed</item>
        <item name="textAppearanceDisplayLarge">@style/Font.GymProFit.DisplayLarge</item>
        <item name="textAppearanceDisplayMedium">@style/Font.GymProFit.DisplayMedium</item>
        <item name="textAppearanceDisplaySmall">@style/Font.GymProFit.DisplaySmall</item>
        <item name="textAppearanceHeadlineLarge">@style/Font.GymProFit.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/Font.GymProFit.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/Font.GymProFit.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/Font.GymProFit.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/Font.GymProFit.TitleMedium</item>
        <item name="textAppearanceTitleSmall">@style/Font.GymProFit.TitleSmall</item>
        <item name="textAppearanceBodyLarge">@style/Font.GymProFit.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/Font.GymProFit.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/Font.GymProFit.BodySmall</item>
        <item name="textAppearanceLabelLarge">@style/Font.GymProFit.LabelLarge</item>
        <item name="textAppearanceLabelMedium">@style/Font.GymProFit.LabelMedium</item>
        <item name="textAppearanceLabelSmall">@style/Font.GymProFit.LabelSmall</item>
    </style>

    <!-- ── Escala tipográfica M3 revestida con Barlow Condensed (fuente global) ──
         Cada estilo hereda del M3 original (tamaños/interlineado) y solo cambia la
         fuente. Se referencian desde el tema (día y noche) → una sola fuente en todo. -->
    <style name="Font.GymProFit.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="fontFamily">@font/barlow_condensed</item>
        <item name="android:fontFamily">@font/barlow_condensed</item>
    </style>
    <style name="Font.GymProFit.DisplayMedium" parent="TextAppearance.Material3.DisplayMedium">
        <item name="fontFamily">@font/barlow_condensed</item>
        <item name="android:fontFamily">@font/barlow_condensed</item>
    </style>
    <style name="Font.GymProFit.DisplaySmall" parent="TextAppearance.Material3.DisplaySmall">
        <item name="fontFamily">@font/barlow_condensed</item>
        <item name="android:fontFamily">@font/barlow_condensed</item>
    </style>
    <style name="Font.GymProFit.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="fontFamily">@font/barlow_condensed</item>
        <item name="android:fontFamily">@font/barlow_condensed</item>
    </style>
    <style name="Font.GymProFit.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="fontFamily">@font/barlow_condensed</item>
        <item name="android:fontFamily">@font/barlow_condensed</item>
    </style>
    <style name="Font.GymProFit.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="fontFamily">@font/barlow_condensed</item>
        <item name="android:fontFamily">@font/barlow_condensed</item>
    </style>
    <!-- Title/Body/Label suben ~4sp sobre M3: Barlow Condensed es estrecha y se lee más
         pequeña que Roboto al mismo tamaño; se compensa para un cuerpo de texto grande y legible. -->
    <style name="Font.GymProFit.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">@font/barlow_condensed</item>
        <item name="android:fontFamily">@font/barlow_condensed</item>
        <item name="android:textSize">26sp</item>
    </style>
    <style name="Font.GymProFit.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="fontFamily">@font/barlow_condensed</item>
        <item name="android:fontFamily">@font/barlow_condensed</item>
        <item name="android:textSize">20sp</item>
    </style>
    <style name="Font.GymProFit.TitleSmall" parent="TextAppearance.Material3.TitleSmall">
        <item name="fontFamily">@font/barlow_condensed</item>
        <item name="android:fontFamily">@font/barlow_condensed</item>
        <item name="android:textSize">18sp</item>
    </style>
    <style name="Font.GymProFit.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="fontFamily">@font/barlow_condensed</item>
        <item name="android:fontFamily">@font/barlow_condensed</item>
        <item name="android:textSize">20sp</item>
    </style>
    <style name="Font.GymProFit.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/barlow_condensed</item>
        <item name="android:fontFamily">@font/barlow_condensed</item>
        <item name="android:textSize">18sp</item>
    </style>
    <style name="Font.GymProFit.BodySmall" parent="TextAppearance.Material3.BodySmall">
        <item name="fontFamily">@font/barlow_condensed</item>
        <item name="android:fontFamily">@font/barlow_condensed</item>
        <item name="android:textSize">16sp</item>
    </style>
    <style name="Font.GymProFit.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="fontFamily">@font/barlow_condensed</item>
        <item name="android:fontFamily">@font/barlow_condensed</item>
        <item name="android:textSize">18sp</item>
    </style>
    <style name="Font.GymProFit.LabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="fontFamily">@font/barlow_condensed</item>
        <item name="android:fontFamily">@font/barlow_condensed</item>
        <item name="android:textSize">15sp</item>
    </style>
    <style name="Font.GymProFit.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="fontFamily">@font/barlow_condensed</item>
        <item name="android:fontFamily">@font/barlow_condensed</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- ── Tipografía display (Barlow Condensed): números y títulos ───────── -->
    <!-- Cifra XXL de stats (kcal de hoy, peso...) -->
    <style name="TextAppearance.GymProFit.Number" parent="TextAppearance.Material3.DisplayMedium">
        <item name="fontFamily">@font/barlow_condensed</item>
        <item name="android:textFontWeight">700</item>
        <item name="android:textSize">52sp</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <!-- Título grande de pantalla -->
    <style name="TextAppearance.GymProFit.Display" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="fontFamily">@font/barlow_condensed</item>
        <item name="android:textFontWeight">700</item>
        <item name="android:textSize">34sp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <!-- Titular de sección/card -->
    <style name="TextAppearance.GymProFit.Headline" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">@font/barlow_condensed</item>
        <item name="android:textFontWeight">600</item>
        <item name="android:textSize">22sp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <!-- Etiqueta/eyebrow en mayúsculas sobre una stat -->
    <style name="TextAppearance.GymProFit.Label" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textAllCaps">true</item>
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>

    <!-- ── Cards: planas, radio 18dp y borde sutil (sin sombras grises) ───── -->
    <style name="Widget.GymProFit.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">?attr/colorSurface</item>
        <item name="cardCornerRadius">18dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/gp_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="rippleColor">@color/gp_primary_container</item>
    </style>

    <!-- ── Botón principal: sólido naranja, contundente ────────────────────── -->
    <style name="Widget.GymProFit.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">14dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- ── Chips: superficie secundaria; seleccionado = naranja container ──── -->
    <style name="Widget.GymProFit.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/chip_background_selector</item>
        <item name="android:textColor">@color/chip_text_selector</item>
        <item name="chipStrokeColor">@color/gp_stroke</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipCornerRadius">12dp</item>
        <item name="checkedIconTint">?attr/colorPrimary</item>
    </style>

    <!-- ── Bottom nav: fondo de superficie + pill naranja en el activo ─────── -->
    <style name="Widget.GymProFit.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">?attr/colorSurface</item>
        <item name="itemIconTint">@color/bottom_nav_item_selector</item>
        <item name="itemTextColor">@color/bottom_nav_item_selector</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.GymProFit.BottomNav.Indicator</item>
        <item name="itemIconSize">24dp</item>
        <item name="android:minHeight">60dp</item>
        <item name="itemPaddingTop">10dp</item>
        <item name="itemPaddingBottom">8dp</item>
    </style>

    <!-- Pill del ítem activo del bottom nav -->
    <style name="Widget.GymProFit.BottomNav.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/gp_primary_container</item>
    </style>

    <!-- ── FAB: naranja sólido ─────────────────────────────────────────────── -->
    <style name="Widget.GymProFit.Fab" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="tint">?attr/colorOnPrimary</item>
    </style>

    <!-- ── Dialogs M3 con esquinas y superficie de la app ──────────────────── -->
    <style name="ThemeOverlay.GymProFit.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/gp_surface</item>
        <item name="dialogCornerRadius">22dp</item>
    </style>

    <!-- ── Snackbar sobre superficie secundaria ────────────────────────────── -->
    <style name="Widget.GymProFit.Snackbar" parent="Widget.Material3.Snackbar">
        <item name="backgroundTint">@color/gp_surface_2</item>
    </style>

    <!-- ── Fila de comida (Nutrición): tile + textos + botón añadir ────────── -->
    <style name="GymProFit.MealRow" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:padding">14dp</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="GymProFit.MealIconTile" parent="">
        <item name="android:layout_width">44dp</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:background">@drawable/bg_accion_tile</item>
    </style>

    <style name="GymProFit.MealIcon" parent="">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
        <item name="android:layout_gravity">center</item>
        <item name="tint">?attr/colorPrimary</item>
        <item name="android:contentDescription">@null</item>
    </style>

    <style name="GymProFit.MealText" parent="">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="GymProFit.MealTitle" parent="">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="GymProFit.MealSub" parent="">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">3dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="GymProFit.MealAdd" parent="">
        <item name="android:layout_width">30dp</item>
        <item name="android:layout_height">30dp</item>
        <item name="android:src">@drawable/ic_add</item>
        <item name="tint">?attr/colorPrimary</item>
        <item name="android:contentDescription">@string/nutricion_agregar</item>
    </style>

    <!-- Estilo del menú emergente (popup) usado en toolbars y menús contextuales -->
    <style name="Widget.GymProFit.PopupMenu" parent="Widget.Material3.PopupMenu">
        <item name="android:dropDownWidth">260dp</item>
        <item name="android:popupElevation">12dp</item>
        <item name="android:popupBackground">@drawable/bg_popup_menu</item>
    </style>
</resources>
