<?xml version="1.0" encoding="utf-8"?><!--
   Sample backup rules file; uncomment and customize as necessary.
   See https://developer.android.com/guide/topics/data/autobackup
   for details.
   Note: This file is ignored for devices older than API 31
   See https://developer.android.com/about/versions/12/backup-restore
-->
<!--
  backup_rules.xml — Reglas de copia de seguridad para Android < 12 (Auto Backup).
  Sin includes/excludes activos: usa el comportamiento por defecto.
-->
<full-backup-content>
    <!-- Excluye el almacén cifrado de tokens: su clave vive en el Android Keystore
         (no se respalda), así que restaurar el archivo cifrado sería inútil y no debe
         viajar en la copia de seguridad. -->
    <exclude domain="sharedpref" path="gymprofit_secure_prefs.xml"/>
</full-backup-content>