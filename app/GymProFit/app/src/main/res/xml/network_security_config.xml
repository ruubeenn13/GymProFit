<?xml version="1.0" encoding="utf-8"?>
<!--
  network_security_config.xml — Política de seguridad de red de la app.
  Por defecto se PROHÍBE el tráfico HTTP en claro (cleartext): todo debe ir por HTTPS.
  Se hace una excepción SOLO para los hosts de desarrollo local (emulador y localhost),
  donde la API corre sobre HTTP. En producción la API debe servirse por HTTPS.
-->
<network-security-config>

    <!-- Regla general: NADA de HTTP en claro salvo lo permitido explícitamente abajo. -->
    <base-config cleartextTrafficPermitted="false" />

    <!-- Desarrollo local: se permite HTTP solo hacia el emulador y el localhost del PC. -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- 10.0.2.2 = alias del emulador Android para el localhost del PC anfitrión -->
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <!--
          Móvil físico en la misma WiFi: añadir aquí la IP LAN del PC, p. ej.:
          <domain includeSubdomains="false">192.168.1.50</domain>
        -->
    </domain-config>

</network-security-config>
