   for details.
-->
<!--
  data_extraction_rules.xml — Reglas de extracción de datos para Android 12+
  (copia en la nube y transferencia entre dispositivos). Sin restricciones activas.
-->
<data-extraction-rules>
    <!-- Copia de seguridad en la nube (Auto Backup) -->
    <cloud-backup>
        <!-- Excluye el almacén cifrado de tokens (clave en Keystore, no restaurable). -->
        <exclude domain="sharedpref" path="gymprofit_secure_prefs.xml"/>
    </cloud-backup>
    <!--
    <device-transfer>
        <include .../>
        <exclude .../>
    </device-transfer>
    -->
</data-extraction-rules>