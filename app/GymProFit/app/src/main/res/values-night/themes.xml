<resources>
    <!--
      themes.xml (values-night) — variante OSCURA (por defecto) del tema atlético.
      Toda la paleta vive en tokens @color/gp_* que ya cambian por qualifier
      (values-night/colors.xml); aquí solo se ajusta lo que no es un color
      con qualifier: los iconos de las barras del sistema.
    -->
    <style name="Theme.GymProFit" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/gp_primary</item>
        <item name="colorOnPrimary">@color/gp_on_primary</item>
        <item name="colorPrimaryContainer">@color/gp_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/gp_on_primary_container</item>
        <item name="colorSecondary">@color/gp_gold</item>
        <item name="colorSurface">@color/gp_surface</item>
        <item name="colorOnSurface">@color/gp_on_surface</item>
        <item name="colorSurfaceVariant">@color/gp_surface_2</item>
        <item name="colorOnSurfaceVariant">@color/gp_text_secondary</item>
        <item name="colorOutline">@color/gp_stroke</item>
        <item name="colorOutlineVariant">@color/gp_stroke</item>
        <item name="colorError">@color/gp_error</item>
        <item name="android:colorBackground">@color/gp_background</item>
        <item name="android:windowBackground">@color/gp_background</item>
        <item name="android:textColorPrimary">@color/gp_on_surface</item>
        <item name="android:textColorSecondary">@color/gp_text_secondary</item>

        <!-- Iconos de estado claros sobre el fondo carbón -->
        <item name="android:statusBarColor">@color/gp_background</item>
        <item name="android:navigationBarColor">@color/gp_background</item>
        <item name="android:windowLightStatusBar">false</item>

        <item name="materialCardViewStyle">@style/Widget.GymProFit.Card</item>
        <item name="materialButtonStyle">@style/Widget.GymProFit.Button</item>
        <item name="chipStyle">@style/Widget.GymProFit.Chip</item>
        <item name="bottomNavigationStyle">@style/Widget.GymProFit.BottomNavigationView</item>
        <item name="floatingActionButtonStyle">@style/Widget.GymProFit.Fab</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.GymProFit.Dialog</item>
        <item name="popupMenuStyle">@style/Widget.GymProFit.PopupMenu</item>
        <item name="android:popupMenuStyle">@style/Widget.GymProFit.PopupMenu</item>
        <item name="snackbarStyle">@style/Widget.GymProFit.Snackbar</item>

        <!-- Fuente ÚNICA en toda la app (Barlow Condensed). Estilos Font.GymProFit.*
             definidos en values/themes.xml (compartidos día/noche). -->
        <item name="android:fontFamily">@font/barlow_condensed</item>
        <item name="fontFamily">@font/barlow_condensed</item>
        <item name="textAppearanceDisplayLarge">@style/Font.GymProFit.DisplayLarge</item>
        <item name="textAppearanceDisplayMedium">@style/Font.GymProFit.DisplayMedium</item>
        <item name="textAppearanceDisplaySmall">@style/Font.GymProFit.DisplaySmall</item>
        <item name="textAppearanceHeadlineLarge">@style/Font.GymProFit.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/Font.GymProFit.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/Font.GymProFit.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/Font.GymProFit.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/Font.GymProFit.TitleMedium</item>
        <item name="textAppearanceTitleSmall">@style/Font.GymProFit.TitleSmall</item>
        <item name="textAppearanceBodyLarge">@style/Font.GymProFit.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/Font.GymProFit.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/Font.GymProFit.BodySmall</item>
        <item name="textAppearanceLabelLarge">@style/Font.GymProFit.LabelLarge</item>
        <item name="textAppearanceLabelMedium">@style/Font.GymProFit.LabelMedium</item>
        <item name="textAppearanceLabelSmall">@style/Font.GymProFit.LabelSmall</item>
    </style>
</resources>
