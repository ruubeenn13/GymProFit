<resources>
    <style name="Theme.GymProFit" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#C9963A</item>
        <item name="colorOnPrimary">#1E1E1E</item>
        <item name="colorPrimaryContainer">#2C2C2C</item>
        <item name="colorOnPrimaryContainer">#D4D4D4</item>
        <item name="colorSurface">#1F1F1F</item>
        <item name="colorOnSurface">#D4D4D4</item>
        <item name="android:colorBackground">#141414</item>
        <item name="android:windowBackground">#141414</item>
        <item name="android:textColorPrimary">#D4D4D4</item>
        <item name="bottomNavigationStyle">@style/Widget.GymProFit.BottomNavigationView</item>
        <item name="popupMenuStyle">@style/Widget.GymProFit.PopupMenu</item>
        <item name="android:popupMenuStyle">@style/Widget.GymProFit.PopupMenu</item>
