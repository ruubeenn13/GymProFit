<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/android:colorBackground">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_resumen_titulo"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"
                android:text="@string/onboarding_resumen_desc"
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurface"
                android:alpha="0.6" />

            <!-- Card principal: objetivo + calorías -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Objetivo -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/onboarding_resumen_objetivo"
                                android:textSize="12sp"
                                android:textColor="?attr/colorOnSurface"
                                android:alpha="0.6" />

                            <TextView
                                android:id="@+id/tvResumenObjetivo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface" />

                        </LinearLayout>

                        <ImageView
                            android:id="@+id/ivResumenObjetivoIcono"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:src="@drawable/ic_objetivo"
                            android:alpha="0.4"
                            android:contentDescription="@null" />

                    </LinearLayout>

                    <!-- Calorías -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="bottom"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:id="@+id/tvResumenCalorias"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="52sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"
                            android:lineSpacingMultiplier="1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_marginBottom="10dp"
                            android:text="@string/onboarding_resumen_kcal_dia"
                            android:textSize="14sp"
                            android:textColor="?attr/colorOnSurface"
                            android:alpha="0.6" />

                    </LinearLayout>

                    <!-- Barra de progreso decorativa -->
                    <ProgressBar
                        android:id="@+id/progressResumen"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:progress="0"
                        android:max="100"
                        android:progressDrawable="@drawable/progress_bar_calorias" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/onboarding_resumen_meta"
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnSurface"
                        android:alpha="0.5" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Grid de macros -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Proteínas -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="?attr/colorSurface">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="14dp" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/nutricion_proteinas" android:textSize="11sp"
                            android:textColor="?attr/colorOnSurface" android:alpha="0.6"
                            android:layout_marginBottom="6dp" />
                        <TextView android:id="@+id/tvResumenProteinas"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="22sp" android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface" android:layout_marginBottom="6dp" />
                        <ProgressBar
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent" android:layout_height="3dp"
                            android:progress="0" android:max="100" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Carbohidratos -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="?attr/colorSurface">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="14dp" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/nutricion_carbohidratos_corto" android:textSize="11sp"
                            android:textColor="?attr/colorOnSurface" android:alpha="0.6"
                            android:layout_marginBottom="6dp" />
                        <TextView android:id="@+id/tvResumenCarbos"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="22sp" android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface" android:layout_marginBottom="6dp" />
                        <ProgressBar
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent" android:layout_height="3dp"
                            android:progress="0" android:max="100" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Grasas -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="?attr/colorSurface">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="14dp" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/nutricion_grasas" android:textSize="11sp"
                            android:textColor="?attr/colorOnSurface" android:alpha="0.6"
                            android:layout_marginBottom="6dp" />
                        <TextView android:id="@+id/tvResumenGrasas"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="22sp" android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface" android:layout_marginBottom="6dp" />
                        <ProgressBar
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent" android:layout_height="3dp"
                            android:progress="0" android:max="100" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Card agua horizontal -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorSurface">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💧" android:textSize="22sp" android:layout_marginEnd="14dp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/onboarding_resumen_agua" android:textSize="12sp"
                            android:textColor="?attr/colorOnSurface" android:alpha="0.6" />
                        <TextView android:id="@+id/tvResumenAgua"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="2dp" android:textSize="20sp"
                            android:textStyle="bold" android:textColor="?attr/colorOnSurface" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Indicador paso 5/5 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="16dp">
            <View android:layout_width="8dp" android:layout_height="4dp" android:background="?attr/colorOnSurface" android:alpha="0.2" android:layout_marginEnd="5dp" />
            <View android:layout_width="8dp" android:layout_height="4dp" android:background="?attr/colorOnSurface" android:alpha="0.2" android:layout_marginEnd="5dp" />
            <View android:layout_width="8dp" android:layout_height="4dp" android:background="?attr/colorOnSurface" android:alpha="0.2" android:layout_marginEnd="5dp" />
            <View android:layout_width="8dp" android:layout_height="4dp" android:background="?attr/colorOnSurface" android:alpha="0.2" android:layout_marginEnd="5dp" />
            <View android:layout_width="32dp" android:layout_height="4dp" android:background="?attr/colorPrimary" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnComenzar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/onboarding_comenzar"
            android:textSize="16sp"
            app:cornerRadius="12dp" />

    </LinearLayout>

</LinearLayout>