<?xml version="1.0" encoding="utf-8"?>
<!--
  item_menu_bottom — item de fila para un menú desplegable/bottom sheet genérico.
  Muestra un icono y una etiqueta de texto, reutilizado en menús contextuales de la app.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:background="?attr/selectableItemBackground">

    <!-- Icono de la opción de menú -->
    <ImageView
        android:id="@+id/ivMenuItemIcon"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_marginEnd="18dp" />

    <!-- Etiqueta de texto de la opción de menú -->
    <TextView
        android:id="@+id/tvMenuItemLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="15sp"
        android:fontFamily="sans-serif" />

</LinearLayout>
