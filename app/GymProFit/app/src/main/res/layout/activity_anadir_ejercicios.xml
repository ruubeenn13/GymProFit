<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_anadir_ejercicios — buscador de ejercicios para añadir a una rutina.
  Permite buscar por texto, filtrar por dificultad y confirmar la selección
  con el botón continuar.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/android:colorBackground">

    <!-- Toolbar con navegación hacia atrás -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorSurface"
        app:title="@string/anadir_ejercicios_titulo"
        app:titleTextColor="?attr/colorOnSurface"
        app:navigationIcon="@drawable/ic_arrow_back" />

    <!-- Área de búsqueda — ocupa todo el espacio disponible -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/crear_rutina_buscar_ejercicio"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:startIconDrawable="@drawable/ic_search">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etBuscarEjercicio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Filtro de dificultad del ejercicio -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            android:scrollbars="none"
            android:fadingEdgeLength="16dp"
            android:requiresFadingEdge="horizontal">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupDificultad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:singleLine="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipDifTodos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/crear_rutina_dificultad_todos"
                    android:checked="true"
                    style="@style/Widget.Material3.Chip.Filter" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipDifPrincipiante"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/rutinas_principiante"
                    style="@style/Widget.Material3.Chip.Filter" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipDifIntermedio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/rutinas_intermedio"
                    style="@style/Widget.Material3.Chip.Filter" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipDifAvanzado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/rutinas_avanzado"
                    style="@style/Widget.Material3.Chip.Filter" />

            </com.google.android.material.chip.ChipGroup>

        </HorizontalScrollView>

        <!-- Resultados de la búsqueda de ejercicios -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvEjerciciosBusqueda"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />

    </LinearLayout>

    <!-- Botón continuar fijo en la parte inferior -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinuar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        android:textSize="15sp"
        app:cornerRadius="12dp" />

</LinearLayout>
