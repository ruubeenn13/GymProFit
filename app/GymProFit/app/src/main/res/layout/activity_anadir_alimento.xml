<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_anadir_alimento — buscador de alimentos para añadir a una comida.
  Muestra un campo de búsqueda, acceso a crear alimento propio y el listado
  filtrado de resultados.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/android:colorBackground">

    <!-- Toolbar -->
    <!-- Volver, título y acceso a crear alimento nuevo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:paddingBottom="12dp"
        android:background="?attr/colorSurface">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/btn_volver" />

        <TextView
            android:id="@+id/tvTituloAnadir"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:textAppearance="@style/TextAppearance.GymProFit.Headline"
            android:text="@string/anadir_alimento_titulo" />

        <Button
            android:id="@+id/btnCrearAlimento"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:text="@string/anadir_alimento_crear"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

    </LinearLayout>

    <!-- Search -->
    <!-- Campo de búsqueda de alimentos -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:hint="@string/anadir_alimento_buscar_hint"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etBuscador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:inputType="text" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- RecyclerView -->
    <!-- Resultados de la búsqueda de alimentos -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAlimentos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

</LinearLayout>
