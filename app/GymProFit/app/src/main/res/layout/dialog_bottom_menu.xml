<?xml version="1.0" encoding="utf-8"?>
<!--
  dialog_bottom_menu — Contenedor genérico para un BottomSheet de menú de opciones.
  Incluye título opcional con separador y un contenedor donde se insertan
  dinámicamente los ítems del menú.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <!-- Título del menú (oculto si no se establece) -->
    <TextView
        android:id="@+id/tvMenuTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="10dp"
        android:textSize="12sp"
        android:letterSpacing="0.08"
        android:fontFamily="sans-serif-medium"
        android:textAllCaps="true"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:maxLines="1"
        android:ellipsize="end"
        android:visibility="gone" />

    <!-- Separador bajo el título -->
    <View
        android:id="@+id/dividerMenuTitle"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOutlineVariant"
        android:visibility="gone" />

    <!-- Contenedor donde se añaden los ítems del menú programáticamente -->
    <LinearLayout
        android:id="@+id/llMenuItems"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />

</LinearLayout>
