<?xml version="1.0" encoding="utf-8"?>
<!--
  item_ejercicio — item de RecyclerView para un ejercicio del catálogo.
  Muestra icono, nombre, descripción y chips de dificultad/calorías, usado en el listado de ejercicios.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="?attr/colorSurface">

    <!-- Fila principal: icono + info + chevron -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Cuerpo humano con la zona trabajada marcada en naranja (estilo
             Symmetry). La demostración/animación real se ve al abrir el detalle. -->
        <ImageView
            android:id="@+id/ivIconoEjercicio"
            android:layout_width="46dp"
            android:layout_height="62dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_body_full"
            android:contentDescription="@null" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNombreEjercicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface" />

            <!-- Descripción limitada a 2 líneas: las de wger son largas y
                 reventaban la card; el texto completo se ve en el detalle -->
            <TextView
                android:id="@+id/tvDescripcionEjercicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="13sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:textColor="?attr/colorOnSurface"
                android:alpha="0.6" />

            <!-- Chips de dificultad y grupo muscular -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipDificultad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    app:chipMinHeight="34dp"
                    android:clickable="false"
                    android:focusable="false"
                    style="@style/Widget.Material3.Chip.Assist" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCalorias"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textSize="14sp"
                    app:chipMinHeight="34dp"
                    android:clickable="false"
                    android:focusable="false"
                    style="@style/Widget.Material3.Chip.Assist" />

            </LinearLayout>

        </LinearLayout>

        <!-- Chevron indicador de navegación al detalle -->
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_chevron_right"
            android:contentDescription="@null" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>