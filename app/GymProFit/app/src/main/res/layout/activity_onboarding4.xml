<?xml version="1.0" encoding="utf-8"?>
<!-- MODIFICADO - 10 objetivos del enum TipoObjetivo en cards horizontales
     con emoji, título, descripción y check al seleccionar -->
<!--
  activity_onboarding4.xml — Onboarding paso 4/5: selección de objetivo personal.
  Lista de 10 cards seleccionables (uno por cada TipoObjetivo) con emoji,
  título, descripción y check visual al marcarse. Progreso + navegación.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/android:colorBackground">

    <!-- Enlace para saltar el paso -->
    <TextView
        android:id="@+id/tvSaltar4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_margin="16dp"
        android:text="@string/onboarding_saltar"
        android:textSize="14sp"
        android:textColor="?attr/colorPrimary"
        android:padding="8dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_objetivo_titulo"
                android:textAppearance="@style/TextAppearance.GymProFit.Display" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="20dp"
                android:text="@string/onboarding_objetivo_desc"
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <!-- PERDER_PESO -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPerderPeso"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:strokeWidth="2dp"
                app:strokeColor="?attr/colorOutlineVariant">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                    <TextView android:layout_width="36dp" android:layout_height="36dp"
                        android:text="🔥" android:textSize="24sp" android:gravity="center" android:layout_marginEnd="14dp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/objetivo_perder_peso" android:textSize="14sp"
                            android:textStyle="bold" android:textColor="?attr/colorOnSurface" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="2dp" android:text="@string/objetivo_perder_peso_desc"
                            android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                    <ImageView android:id="@+id/ivCheckPerderPeso" android:layout_width="20dp"
                        android:layout_height="20dp" android:src="@drawable/ic_check"
                        android:visibility="gone" android:contentDescription="@null" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- GANAR_MASA_MUSCULAR -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardGanarMusculo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:strokeWidth="2dp"
                app:strokeColor="?attr/colorOutlineVariant">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                    <TextView android:layout_width="36dp" android:layout_height="36dp"
                        android:text="💪" android:textSize="24sp" android:gravity="center" android:layout_marginEnd="14dp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/objetivo_ganar_musculo" android:textSize="14sp"
                            android:textStyle="bold" android:textColor="?attr/colorOnSurface" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="2dp" android:text="@string/objetivo_ganar_musculo_desc"
                            android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                    <ImageView android:id="@+id/ivCheckGanarMusculo" android:layout_width="20dp"
                        android:layout_height="20dp" android:src="@drawable/ic_check"
                        android:visibility="gone" android:contentDescription="@null" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- MANTENER_PESO -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMantener"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:strokeWidth="2dp"
                app:strokeColor="?attr/colorOutlineVariant">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                    <TextView android:layout_width="36dp" android:layout_height="36dp"
                        android:text="⚖️" android:textSize="24sp" android:gravity="center" android:layout_marginEnd="14dp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/objetivo_mantener" android:textSize="14sp"
                            android:textStyle="bold" android:textColor="?attr/colorOnSurface" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="2dp" android:text="@string/objetivo_mantener_desc"
                            android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                    <ImageView android:id="@+id/ivCheckMantener" android:layout_width="20dp"
                        android:layout_height="20dp" android:src="@drawable/ic_check"
                        android:visibility="gone" android:contentDescription="@null" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- MEJORAR_RESISTENCIA -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardResistencia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:strokeWidth="2dp"
                app:strokeColor="?attr/colorOutlineVariant">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                    <TextView android:layout_width="36dp" android:layout_height="36dp"
                        android:text="🏃" android:textSize="24sp" android:gravity="center" android:layout_marginEnd="14dp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/objetivo_resistencia" android:textSize="14sp"
                            android:textStyle="bold" android:textColor="?attr/colorOnSurface" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="2dp" android:text="@string/objetivo_resistencia_desc"
                            android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                    <ImageView android:id="@+id/ivCheckResistencia" android:layout_width="20dp"
                        android:layout_height="20dp" android:src="@drawable/ic_check"
                        android:visibility="gone" android:contentDescription="@null" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- MEJORAR_FUERZA -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardFuerza"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:strokeWidth="2dp"
                app:strokeColor="?attr/colorOutlineVariant">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                    <TextView android:layout_width="36dp" android:layout_height="36dp"
                        android:text="🦾" android:textSize="24sp" android:gravity="center" android:layout_marginEnd="14dp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/objetivo_fuerza" android:textSize="14sp"
                            android:textStyle="bold" android:textColor="?attr/colorOnSurface" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="2dp" android:text="@string/objetivo_fuerza_desc"
                            android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                    <ImageView android:id="@+id/ivCheckFuerza" android:layout_width="20dp"
                        android:layout_height="20dp" android:src="@drawable/ic_check"
                        android:visibility="gone" android:contentDescription="@null" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- REDUCIR_GRASA_CORPORAL -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardReducirGrasa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:strokeWidth="2dp"
                app:strokeColor="?attr/colorOutlineVariant">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                    <TextView android:layout_width="36dp" android:layout_height="36dp"
                        android:text="📉" android:textSize="24sp" android:gravity="center" android:layout_marginEnd="14dp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/objetivo_reducir_grasa" android:textSize="14sp"
                            android:textStyle="bold" android:textColor="?attr/colorOnSurface" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="2dp" android:text="@string/objetivo_reducir_grasa_desc"
                            android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                    <ImageView android:id="@+id/ivCheckReducirGrasa" android:layout_width="20dp"
                        android:layout_height="20dp" android:src="@drawable/ic_check"
                        android:visibility="gone" android:contentDescription="@null" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- MEJORAR_FLEXIBILIDAD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardFlexibilidad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:strokeWidth="2dp"
                app:strokeColor="?attr/colorOutlineVariant">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                    <TextView android:layout_width="36dp" android:layout_height="36dp"
                        android:text="🧘" android:textSize="24sp" android:gravity="center" android:layout_marginEnd="14dp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/objetivo_flexibilidad" android:textSize="14sp"
                            android:textStyle="bold" android:textColor="?attr/colorOnSurface" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="2dp" android:text="@string/objetivo_flexibilidad_desc"
                            android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                    <ImageView android:id="@+id/ivCheckFlexibilidad" android:layout_width="20dp"
                        android:layout_height="20dp" android:src="@drawable/ic_check"
                        android:visibility="gone" android:contentDescription="@null" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- MEJORAR_VELOCIDAD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardVelocidad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:strokeWidth="2dp"
                app:strokeColor="?attr/colorOutlineVariant">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                    <TextView android:layout_width="36dp" android:layout_height="36dp"
                        android:text="⚡" android:textSize="24sp" android:gravity="center" android:layout_marginEnd="14dp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/objetivo_velocidad" android:textSize="14sp"
                            android:textStyle="bold" android:textColor="?attr/colorOnSurface" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="2dp" android:text="@string/objetivo_velocidad_desc"
                            android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                    <ImageView android:id="@+id/ivCheckVelocidad" android:layout_width="20dp"
                        android:layout_height="20dp" android:src="@drawable/ic_check"
                        android:visibility="gone" android:contentDescription="@null" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- AUMENTAR_CALORIAS -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAumentarCalorias"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:strokeWidth="2dp"
                app:strokeColor="?attr/colorOutlineVariant">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                    <TextView android:layout_width="36dp" android:layout_height="36dp"
                        android:text="🍽️" android:textSize="24sp" android:gravity="center" android:layout_marginEnd="14dp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/objetivo_aumentar_calorias" android:textSize="14sp"
                            android:textStyle="bold" android:textColor="?attr/colorOnSurface" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="2dp" android:text="@string/objetivo_aumentar_calorias_desc"
                            android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                    <ImageView android:id="@+id/ivCheckAumentarCalorias" android:layout_width="20dp"
                        android:layout_height="20dp" android:src="@drawable/ic_check"
                        android:visibility="gone" android:contentDescription="@null" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- MEJORAR_MOVILIDAD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMovilidad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:strokeWidth="2dp"
                app:strokeColor="?attr/colorOutlineVariant">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                    <TextView android:layout_width="36dp" android:layout_height="36dp"
                        android:text="🤸" android:textSize="24sp" android:gravity="center" android:layout_marginEnd="14dp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/objetivo_movilidad" android:textSize="14sp"
                            android:textStyle="bold" android:textColor="?attr/colorOnSurface" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="2dp" android:text="@string/objetivo_movilidad_desc"
                            android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                    <ImageView android:id="@+id/ivCheckMovilidad" android:layout_width="20dp"
                        android:layout_height="20dp" android:src="@drawable/ic_check"
                        android:visibility="gone" android:contentDescription="@null" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Indicador paso 4/5 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="16dp">
            <View android:layout_width="8dp" android:layout_height="4dp" android:background="?attr/colorSurfaceVariant" android:layout_marginEnd="5dp" />
            <View android:layout_width="8dp" android:layout_height="4dp" android:background="?attr/colorSurfaceVariant" android:layout_marginEnd="5dp" />
            <View android:layout_width="8dp" android:layout_height="4dp" android:background="?attr/colorSurfaceVariant" android:layout_marginEnd="5dp" />
            <View android:layout_width="32dp" android:layout_height="4dp" android:background="?attr/colorPrimary" android:layout_marginEnd="5dp" />
            <View android:layout_width="8dp" android:layout_height="4dp" android:background="?attr/colorSurfaceVariant" />
        </LinearLayout>

        <!-- Botones de navegación anterior/siguiente -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAnterior4"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                android:layout_marginEnd="8dp" android:text="@string/onboarding_anterior" app:cornerRadius="12dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSiguiente4"
                android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                android:layout_marginStart="8dp" android:text="@string/onboarding_siguiente" app:cornerRadius="12dp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>