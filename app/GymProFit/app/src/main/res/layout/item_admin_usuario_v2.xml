<?xml version="1.0" encoding="utf-8"?>
<!--
  item_admin_usuario_v2 — Item de RecyclerView (variante 2) para la lista de usuarios en el panel de administración
  Muestra avatar, nombre de usuario, email, chips de rol/estado y un botón de acciones.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="?attr/colorSurface"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/colorOutlineVariant">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_perfil"
            android:alpha="0.4"
            android:contentDescription="@null" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvUsernameAdmin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:id="@+id/tvEmailAdmin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Chips de rol/estado + botón de acciones -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipRolAdmin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:clickable="false"
                android:focusable="false"
                app:chipMinHeight="24dp"
                app:chipBackgroundColor="?attr/colorSurfaceVariant"
                android:textColor="?attr/colorOnSurfaceVariant"
                style="@style/Widget.Material3.Chip.Assist" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipEstadoAdmin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textSize="10sp"
                android:clickable="false"
                android:focusable="false"
                app:chipMinHeight="24dp"
                style="@style/Widget.Material3.Chip.Assist" />

            <ImageView
                android:id="@+id/btnAccionesUsuario"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_more_vert"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@null" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
