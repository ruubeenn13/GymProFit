<?xml version="1.0" encoding="utf-8"?>
<!--
  dialog_gramos — Diálogo para introducir la cantidad en gramos de un alimento
  y previsualizar sus macronutrientes calculados en tiempo real.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Campo de entrada de gramos -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:hint="@string/anadir_alimento_gramos_hint"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etGramos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:singleLine="true" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Previsualización de macros calculados para la cantidad introducida -->
    <TextView
        android:id="@+id/tvPreviewMacros"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="?attr/colorOnSurface"
        android:alpha="0.75"
        android:gravity="center"
        android:text="0 kcal | 0g prot | 0g carbos | 0g grasas" />

</LinearLayout>
