<?xml version="1.0" encoding="utf-8"?>
<!-- MODIFICADO - Añadido ChipGroup de nivel de actividad física -->
<!--
  activity_onboarding3.xml — Onboarding paso 3/5: medidas corporales y actividad.
  Formulario con peso, altura y selección del nivel de actividad física (chips).
  Incluye indicador de progreso y navegación anterior/siguiente.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/android:colorBackground">

    <!-- Enlace para saltar el paso -->
    <TextView
        android:id="@+id/tvSaltar3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_margin="16dp"
        android:text="@string/onboarding_saltar"
        android:textSize="14sp"
        android:textColor="?attr/colorPrimary"
        android:padding="8dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_medidas_titulo"
                android:textAppearance="@style/TextAppearance.GymProFit.Display" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp"
                android:text="@string/onboarding_medidas_desc"
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <!-- Peso - manteniendo el paddingStart/End del usuario -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/perfil_peso"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:startIconDrawable="@drawable/ic_peso"
                app:suffixText="kg">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPesoOnboarding"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:paddingStart="40dp"
                    android:paddingEnd="40dp"
                    android:maxLines="1" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Altura - manteniendo el paddingStart/End del usuario -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="@string/perfil_altura"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:startIconDrawable="@drawable/ic_altura"
                app:suffixText="cm">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etAlturaOnboarding"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:paddingStart="40dp"
                    android:paddingEnd="40dp"
                    android:maxLines="1" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Nivel de actividad - NUEVO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="10dp"
                android:text="@string/onboarding_actividad_label"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.12"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <!-- ChipGroup en scroll horizontal para que quepan todos en una línea -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupActividad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    app:chipSpacingHorizontal="4dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipSedentario"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/onboarding_sedentario"
                        android:textSize="13sp"
                        app:chipMinHeight="32dp"
                        app:chipStartPadding="8dp"
                        app:chipEndPadding="8dp"
                        style="@style/Widget.Material3.Chip.Filter" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipLigero"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/onboarding_ligero"
                        android:textSize="13sp"
                        app:chipMinHeight="32dp"
                        app:chipStartPadding="8dp"
                        app:chipEndPadding="8dp"
                        style="@style/Widget.Material3.Chip.Filter" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipModerado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/onboarding_moderado"
                        android:checked="true"
                        android:textSize="13sp"
                        app:chipMinHeight="32dp"
                        app:chipStartPadding="8dp"
                        app:chipEndPadding="8dp"
                        style="@style/Widget.Material3.Chip.Filter" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipActivo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/onboarding_activo"
                        android:textSize="13sp"
                        app:chipMinHeight="32dp"
                        app:chipStartPadding="8dp"
                        app:chipEndPadding="8dp"
                        style="@style/Widget.Material3.Chip.Filter" />

                </com.google.android.material.chip.ChipGroup>

            </HorizontalScrollView>

        </LinearLayout>

    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Indicador paso 3/5 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">
            <View android:layout_width="8dp" android:layout_height="4dp" android:background="?attr/colorSurfaceVariant" android:layout_marginEnd="5dp" />
            <View android:layout_width="8dp" android:layout_height="4dp" android:background="?attr/colorSurfaceVariant" android:layout_marginEnd="5dp" />
            <View android:layout_width="32dp" android:layout_height="4dp" android:background="?attr/colorPrimary" android:layout_marginEnd="5dp" />
            <View android:layout_width="8dp" android:layout_height="4dp" android:background="?attr/colorSurfaceVariant" android:layout_marginEnd="5dp" />
            <View android:layout_width="8dp" android:layout_height="4dp" android:background="?attr/colorSurfaceVariant" />
        </LinearLayout>

        <!-- Botones de navegación anterior/siguiente -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAnterior3"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/onboarding_anterior"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSiguiente3"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/onboarding_siguiente"
                app:cornerRadius="12dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>