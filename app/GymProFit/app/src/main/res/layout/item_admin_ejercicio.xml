<?xml version="1.0" encoding="utf-8"?>
<!--
  item_admin_ejercicio — Item de RecyclerView para la lista de ejercicios en el panel de administración
  Muestra nombre, descripción, chips de grupo muscular/dificultad/estado y un botón de acciones.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="?attr/colorSurface"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/colorOutlineVariant">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Fila 1: nombre + descripción + botón acciones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNombreEjercicio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/tvDescripcionEjercicio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <ImageView
                android:id="@+id/btnAccionesEjercicio"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_more_vert"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@null" />

        </LinearLayout>

        <!-- Fila 2: chips de grupo muscular, dificultad y estado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipGrupoEjercicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:clickable="false"
                android:focusable="false"
                app:chipMinHeight="24dp"
                app:chipBackgroundColor="?attr/colorSurfaceVariant"
                android:textColor="?attr/colorOnSurfaceVariant"
                style="@style/Widget.Material3.Chip.Assist" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDificultadEjercicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textSize="10sp"
                android:clickable="false"
                android:focusable="false"
                app:chipMinHeight="24dp"
                app:chipBackgroundColor="?attr/colorSurfaceVariant"
                android:textColor="?attr/colorOnSurfaceVariant"
                style="@style/Widget.Material3.Chip.Assist" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipEstadoEjercicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textSize="10sp"
                android:clickable="false"
                android:focusable="false"
                app:chipMinHeight="24dp"
                style="@style/Widget.Material3.Chip.Assist" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
