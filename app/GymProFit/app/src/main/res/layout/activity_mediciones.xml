<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_mediciones.xml — Pantalla de mediciones corporales del usuario.
  Muestra la última medición (peso, altura, grasa, músculo, perímetros, notas) en
  filas pulsables, un estado vacío si no hay datos, y un FAB para registrar una nueva.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/android:colorBackground">

    <!-- Cabecera -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:paddingBottom="12dp"
        android:background="?attr/colorSurface">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@null" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/mediciones_titulo"
            android:textAppearance="@style/TextAppearance.GymProFit.Headline"
            android:textSize="24sp" />

    </LinearLayout>

    <!-- Área de contenido -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Estado vacío -->
        <LinearLayout
            android:id="@+id/tvVacio"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_peso"
                android:alpha="0.3"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/mediciones_sin_mediciones"
                android:textSize="16sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/medicion_sin_datos_subtitulo"
                android:textSize="13sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:gravity="center" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegistrarPrimera"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/medicion_registrar_primera"
                app:icon="@drawable/ic_add" />

        </LinearLayout>

        <!-- Contenido con mediciones -->
        <ScrollView
            android:id="@+id/scrollMediciones"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:paddingBottom="80dp">

                <TextView
                    android:id="@+id/tvFechaUltima"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <!-- Gráfica de evolución del peso (oculta si hay <2 registros con peso) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardGraficaPeso"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvGraficaTitulo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/medicion_grafica_peso"
                            android:textAppearance="@style/TextAppearance.GymProFit.Label"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <!-- Toggle de métrica: qué medida se representa -->
                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/chipsMetrica"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            app:singleLine="true"
                            app:singleSelection="true"
                            app:selectionRequired="true">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipMetPeso"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/grafica_met_peso"
                                android:checked="true" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipMetGrasa"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/grafica_met_grasa" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipMetCintura"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/grafica_met_cintura" />

                        </com.google.android.material.chip.ChipGroup>

                        <!-- Área de gráfica: la línea o, si esa métrica no tiene ≥2 datos,
                             un mensaje de estado vacío (la card y los chips NO desaparecen). -->
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="180dp"
                            android:layout_marginTop="8dp">

                            <com.github.mikephil.charting.charts.LineChart
                                android:id="@+id/chartPeso"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent" />

                            <TextView
                                android:id="@+id/tvGraficaVacia"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="@string/grafica_sin_datos"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="14sp"
                                android:gravity="center"
                                android:visibility="gone" />

                        </FrameLayout>

                        <!-- Rango temporal de la gráfica -->
                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/chipsRango"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            app:singleLine="true"
                            app:singleSelection="true"
                            app:selectionRequired="true">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipRango30"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/grafica_rango_30" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipRango90"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/grafica_rango_90" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipRangoTodo"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/grafica_rango_todo"
                                android:checked="true" />

                        </com.google.android.material.chip.ChipGroup>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="4dp">

                        <!-- Peso -->
                        <LinearLayout
                            android:id="@+id/rowPeso"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/perfil_peso"
                                android:textSize="15sp"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:id="@+id/tvPesoVal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorPrimary" />

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_marginStart="8dp"
                                android:src="@drawable/ic_chevron_right"
                                android:alpha="0.4"
                                android:contentDescription="@null" />

                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:layout_marginStart="16dp" android:background="?attr/colorOutlineVariant" />

                        <!-- Grasa corporal -->
                        <LinearLayout
                            android:id="@+id/rowGrasa"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/medicion_label_grasa"
                                android:textSize="15sp"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:id="@+id/tvGrasaVal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorPrimary" />

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_marginStart="8dp"
                                android:src="@drawable/ic_chevron_right"
                                android:alpha="0.4"
                                android:contentDescription="@null" />

                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:layout_marginStart="16dp" android:background="?attr/colorOutlineVariant" />

                        <!-- Cintura -->
                        <LinearLayout
                            android:id="@+id/rowCintura"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/medicion_label_cintura"
                                android:textSize="15sp"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:id="@+id/tvCinturaVal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorPrimary" />

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_marginStart="8dp"
                                android:src="@drawable/ic_chevron_right"
                                android:alpha="0.4"
                                android:contentDescription="@null" />

                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:layout_marginStart="16dp" android:background="?attr/colorOutlineVariant" />

                        <!-- Notas -->
                        <LinearLayout
                            android:id="@+id/rowNotas"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/medicion_label_notas"
                                android:textSize="15sp"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:id="@+id/tvNotasVal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:maxWidth="140dp"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorPrimary" />

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_marginStart="8dp"
                                android:src="@drawable/ic_chevron_right"
                                android:alpha="0.4"
                                android:contentDescription="@null" />

                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:layout_marginStart="16dp" android:background="?attr/colorOutlineVariant" />

                        <!-- Toggle: despliega/oculta las medidas avanzadas (nicho) -->
                        <LinearLayout
                            android:id="@+id/rowMasDetalles"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:id="@+id/tvMasDetalles"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/medicion_mas_detalles"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorPrimary" />

                        </LinearLayout>

                        <!-- Medidas avanzadas (colapsable, oculto por defecto) -->
                        <LinearLayout
                            android:id="@+id/layoutMasDetalles"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <!-- Masa muscular -->
                            <LinearLayout
                                android:id="@+id/rowMusculo"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/medicion_label_musculo"
                                    android:textSize="15sp"
                                    android:textColor="?attr/colorOnSurface" />

                                <TextView
                                    android:id="@+id/tvMusculoVal"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="?attr/colorPrimary" />

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_marginStart="8dp"
                                    android:src="@drawable/ic_chevron_right"
                                    android:alpha="0.4"
                                    android:contentDescription="@null" />

                            </LinearLayout>

                            <View android:layout_width="match_parent" android:layout_height="1dp"
                                android:layout_marginStart="16dp" android:background="?attr/colorOutlineVariant" />

                            <!-- Pecho -->
                            <LinearLayout
                                android:id="@+id/rowPecho"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/medicion_label_pecho"
                                    android:textSize="15sp"
                                    android:textColor="?attr/colorOnSurface" />

                                <TextView
                                    android:id="@+id/tvPechoVal"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="?attr/colorPrimary" />

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_marginStart="8dp"
                                    android:src="@drawable/ic_chevron_right"
                                    android:alpha="0.4"
                                    android:contentDescription="@null" />

                            </LinearLayout>

                            <View android:layout_width="match_parent" android:layout_height="1dp"
                                android:layout_marginStart="16dp" android:background="?attr/colorOutlineVariant" />

                            <!-- Brazos -->
                            <LinearLayout
                                android:id="@+id/rowBrazos"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/medicion_label_brazos"
                                    android:textSize="15sp"
                                    android:textColor="?attr/colorOnSurface" />

                                <TextView
                                    android:id="@+id/tvBrazosVal"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="?attr/colorPrimary" />

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_marginStart="8dp"
                                    android:src="@drawable/ic_chevron_right"
                                    android:alpha="0.4"
                                    android:contentDescription="@null" />

                            </LinearLayout>

                            <View android:layout_width="match_parent" android:layout_height="1dp"
                                android:layout_marginStart="16dp" android:background="?attr/colorOutlineVariant" />

                            <!-- Piernas -->
                            <LinearLayout
                                android:id="@+id/rowPiernas"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/medicion_label_piernas"
                                    android:textSize="15sp"
                                    android:textColor="?attr/colorOnSurface" />

                                <TextView
                                    android:id="@+id/tvPiernasVal"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="?attr/colorPrimary" />

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_marginStart="8dp"
                                    android:src="@drawable/ic_chevron_right"
                                    android:alpha="0.4"
                                    android:contentDescription="@null" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </ScrollView>

    </FrameLayout>

</LinearLayout>
