<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_nutricion.xml — seguimiento nutricional diario (estilo atlético).
  Calorías del día como número XXL (Barlow Condensed) sobre naranja con
  barra de progreso, macros con cifras grandes y barras tintadas, y las
  5 comidas del día como accesos para registrar. Navegación inferior.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/android:colorBackground">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Cabecera -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="22dp"
                android:paddingStart="20dp"
                android:paddingEnd="6dp"
                android:paddingBottom="6dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/nutricion_seguimiento"
                    android:textAppearance="@style/TextAppearance.GymProFit.Display" />

                <ImageView
                    android:id="@+id/btnEstadisticas"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_stats"
                    android:padding="8dp"
                    app:tint="?attr/colorOnSurface"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@string/nutricion_estadisticas" />

                <ImageView
                    android:id="@+id/btnMenuOpciones"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_more_vert"
                    android:padding="8dp"
                    app:tint="?attr/colorOnSurface"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@null" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="6dp"
                android:paddingBottom="16dp">

                <!-- ── CALORÍAS DEL DÍA: número XXL sobre naranja ── -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="?attr/colorPrimary">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="22dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/nutricion_calorias_hoy"
                            android:textAllCaps="true"
                            android:textSize="13sp"
                            android:letterSpacing="0.12"
                            android:textColor="?attr/colorOnPrimary"
                            android:alpha="0.85" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="bottom">

                            <TextView
                                android:id="@+id/tvCaloriasActuales"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:fontFamily="@font/barlow_condensed"
                                android:textFontWeight="700"
                                android:textSize="60sp"
                                android:includeFontPadding="false"
                                android:textColor="?attr/colorOnPrimary" />

                            <TextView
                                android:id="@+id/tvCaloriasObjetivo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_marginBottom="12dp"
                                android:text="/ 2000 kcal"
                                android:textSize="15sp"
                                android:textColor="?attr/colorOnPrimary"
                                android:alpha="0.85" />

                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/progressCalorias"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="10dp"
                            android:layout_marginTop="10dp"
                            android:progress="0"
                            android:max="100"
                            android:progressDrawable="@drawable/progress_bar_calorias" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/nutricion_objetivo"
                            android:textSize="12sp"
                            android:textColor="?attr/colorOnPrimary"
                            android:alpha="0.7" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ── MACROS: proteínas / carbos / grasas ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp"
                            android:gravity="center_horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/nutricion_proteinas"
                                android:textSize="11sp"
                                android:textColor="?attr/colorOnSurfaceVariant" />

                            <TextView
                                android:id="@+id/tvProteinasActuales"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="0g"
                                android:fontFamily="@font/barlow_condensed"
                                android:textFontWeight="700"
                                android:textSize="26sp"
                                android:includeFontPadding="false"
                                android:textColor="?attr/colorOnSurface" />

                            <ProgressBar
                                android:id="@+id/progressProteinas"
                                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                                android:layout_width="match_parent"
                                android:layout_height="5dp"
                                android:layout_marginTop="8dp"
                                android:progress="0"
                                android:max="100"
                                android:progressTint="?attr/colorPrimary"
                                android:progressBackgroundTint="?attr/colorSurfaceVariant" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="5dp"
                        android:layout_marginEnd="5dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp"
                            android:gravity="center_horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/nutricion_carbohidratos"
                                android:textSize="11sp"
                                android:textColor="?attr/colorOnSurfaceVariant" />

                            <TextView
                                android:id="@+id/tvCarbosActuales"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="0g"
                                android:fontFamily="@font/barlow_condensed"
                                android:textFontWeight="700"
                                android:textSize="26sp"
                                android:includeFontPadding="false"
                                android:textColor="?attr/colorOnSurface" />

                            <ProgressBar
                                android:id="@+id/progressCarbos"
                                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                                android:layout_width="match_parent"
                                android:layout_height="5dp"
                                android:layout_marginTop="8dp"
                                android:progress="0"
                                android:max="100"
                                android:progressTint="?attr/colorPrimary"
                                android:progressBackgroundTint="?attr/colorSurfaceVariant" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="5dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp"
                            android:gravity="center_horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/nutricion_grasas"
                                android:textSize="11sp"
                                android:textColor="?attr/colorOnSurfaceVariant" />

                            <TextView
                                android:id="@+id/tvGrasasActuales"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="0g"
                                android:fontFamily="@font/barlow_condensed"
                                android:textFontWeight="700"
                                android:textSize="26sp"
                                android:includeFontPadding="false"
                                android:textColor="?attr/colorOnSurface" />

                            <ProgressBar
                                android:id="@+id/progressGrasas"
                                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                                android:layout_width="match_parent"
                                android:layout_height="5dp"
                                android:layout_marginTop="8dp"
                                android:progress="0"
                                android:max="100"
                                android:progressTint="?attr/colorPrimary"
                                android:progressBackgroundTint="?attr/colorSurfaceVariant" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- ── COMIDAS DE HOY ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="26dp"
                    android:layout_marginBottom="12dp"
                    android:text="@string/comidas_hoy"
                    android:textAppearance="@style/TextAppearance.GymProFit.Headline" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardDesayuno"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout style="@style/GymProFit.MealRow">

                        <FrameLayout style="@style/GymProFit.MealIconTile">
                            <ImageView style="@style/GymProFit.MealIcon" android:src="@drawable/ic_nutricion" />
                        </FrameLayout>

                        <LinearLayout style="@style/GymProFit.MealText">
                            <TextView style="@style/GymProFit.MealTitle" android:text="@string/nutricion_desayuno" />
                            <TextView android:id="@+id/tvSubDesayuno" style="@style/GymProFit.MealSub" android:text="@string/sin_registrar" />
                        </LinearLayout>

                        <ImageView style="@style/GymProFit.MealAdd" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAlmuerzo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout style="@style/GymProFit.MealRow">

                        <FrameLayout style="@style/GymProFit.MealIconTile">
                            <ImageView style="@style/GymProFit.MealIcon" android:src="@drawable/ic_nutricion" />
                        </FrameLayout>

                        <LinearLayout style="@style/GymProFit.MealText">
                            <TextView style="@style/GymProFit.MealTitle" android:text="@string/nutricion_almuerzo" />
                            <TextView android:id="@+id/tvSubAlmuerzo" style="@style/GymProFit.MealSub" android:text="@string/sin_registrar" />
                        </LinearLayout>

                        <ImageView style="@style/GymProFit.MealAdd" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardComida"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout style="@style/GymProFit.MealRow">

                        <FrameLayout style="@style/GymProFit.MealIconTile">
                            <ImageView style="@style/GymProFit.MealIcon" android:src="@drawable/ic_nutricion" />
                        </FrameLayout>

                        <LinearLayout style="@style/GymProFit.MealText">
                            <TextView style="@style/GymProFit.MealTitle" android:text="@string/nutricion_comida" />
                            <TextView android:id="@+id/tvSubComida" style="@style/GymProFit.MealSub" android:text="@string/sin_registrar" />
                        </LinearLayout>

                        <ImageView style="@style/GymProFit.MealAdd" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMerienda"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout style="@style/GymProFit.MealRow">

                        <FrameLayout style="@style/GymProFit.MealIconTile">
                            <ImageView style="@style/GymProFit.MealIcon" android:src="@drawable/ic_nutricion" />
                        </FrameLayout>

                        <LinearLayout style="@style/GymProFit.MealText">
                            <TextView style="@style/GymProFit.MealTitle" android:text="@string/nutricion_merienda" />
                            <TextView android:id="@+id/tvSubMerienda" style="@style/GymProFit.MealSub" android:text="@string/sin_registrar" />
                        </LinearLayout>

                        <ImageView style="@style/GymProFit.MealAdd" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCena"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout style="@style/GymProFit.MealRow">

                        <FrameLayout style="@style/GymProFit.MealIconTile">
                            <ImageView style="@style/GymProFit.MealIcon" android:src="@drawable/ic_nutricion" />
                        </FrameLayout>

                        <LinearLayout style="@style/GymProFit.MealText">
                            <TextView style="@style/GymProFit.MealTitle" android:text="@string/nutricion_cena" />
                            <TextView android:id="@+id/tvSubCena" style="@style/GymProFit.MealSub" android:text="@string/sin_registrar" />
                        </LinearLayout>

                        <ImageView style="@style/GymProFit.MealAdd" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
